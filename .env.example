E2B_API_KEY=e2b_...
# 'codex' is E2B's public template with codex CLI + node + npm pre-installed.
# Bootstrap will install bun, the Codex SDK runner deps, and a Next.js app on first project create.
# Leave empty to use E2B base (slower: also installs codex from npm).
E2B_TEMPLATE_ID=codex
PORT=8787
DATABASE_PATH=./data/node-app.db
# OPENAI_API_KEY is NOT required — Codex authenticates per-project via ChatGPT login (device flow).
